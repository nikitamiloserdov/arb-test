          {
            "name": "Send magic link",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const response = pm.response.json();",
                    "pm.environment.set('registrationSessionId', response.sessionId);",
                    ""
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              }
            ],
            "request": {
              "method": "POST",
              "header": [],
              "body": {
                "mode": "raw",
                "raw": "{\n    \"email\": \"{{mail_address}}\"    \n}",
                "options": {
                  "raw": {
                    "language": "json"
                  }
                }
              },
              "url": {
                "raw": "{{r2u-domain}}/auth/magic-link/send",
                "host": [
                  "{{r2u-domain}}"
                ],
                "path": [
                  "auth",
                  "magic-link",
                  "send"
                ]
              }
            },
            "response": []
          },
          {
            "name": "https://api.mail.tm/messages",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const body = pm.response.json()\r",
                    "\r",
                    "const messageId = body[\"hydra:member\"][0].id\r",
                    "\r",
                    "pm.environment.set(\"message_id\", messageId)"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              },
              {
                "listen": "prerequest",
                "script": {
                  "exec": [
                    "pm.sendRequest(\"https://postman-echo.com/delay/3\", function (err, res) {\r",
                    "    console.log(\"Waited 3 seconds\");\r",
                    "});"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              }
            ],
            "request": {
              "auth": {
                "type": "noauth"
              },
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{mail_token}}",
                  "type": "text"
                }
              ],
              "url": {
                "raw": "https://api.mail.tm/messages",
                "protocol": "https",
                "host": [
                  "api",
                  "mail",
                  "tm"
                ],
                "path": [
                  "messages"
                ]
              }
            },
            "response": []
          },
          {
            "name": "https://api.mail.tm/messages/{{message_id}}",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const body = pm.response.json()\r",
                    "\r",
                    "const text = body.text || body.html\r",
                    "\r",
                    "const match = text.match(/token=([a-z0-9]+)/i)\r",
                    "\r",
                    "if (match) {\r",
                    "    pm.environment.set(\"magic_token\", match[1])\r",
                    "}"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              }
            ],
            "request": {
              "auth": {
                "type": "noauth"
              },
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{mail_token}}",
                  "type": "text"
                }
              ],
              "url": {
                "raw": "https://api.mail.tm/messages/{{message_id}}",
                "protocol": "https",
                "host": [
                  "api",
                  "mail",
                  "tm"
                ],
                "path": [
                  "messages",
                  "{{message_id}}"
                ]
              }
            },
            "response": []
          },
          {
            "name": "Magic link redeem",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const response = pm.response.json();",
                    "",
                    "if (response.deviceSessionToken) {",
                    "  pm.environment.set('deviceSessionToken', response.deviceSessionToken);",
                    "}"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              }
            ],
            "request": {
              "method": "POST",
              "header": [],
              "body": {
                "mode": "raw",
                "raw": "{\n    \"sessionId\": \"{{registrationSessionId}}\",\n    \"token\": \"{{magic_token}}\"    \n}",
                "options": {
                  "raw": {
                    "language": "json"
                  }
                }
              },
              "url": {
                "raw": "{{r2u-domain}}/auth/magic-link/redeem",
                "host": [
                  "{{r2u-domain}}"
                ],
                "path": [
                  "auth",
                  "magic-link",
                  "redeem"
                ]
              }
            },
            "response": []
          }
        ]
