    "item": [
      {
        "name": "Auth",
        "item": [
          {
            "name": "https://api.mail.tm/domains",
            "event": [
              {
                "listen": "prerequest",
                "script": {
                  "exec": [
                    "const random = Math.floor(Math.random() * 100000)\r",
                    "\r",
                    "const email = `test${random}@${pm.environment.get(\"mail_domain\")}`\r",
                    "const password = \"123456\"\r",
                    "\r",
                    "pm.environment.set(\"mail_address\", email)\r",
                    "pm.environment.set(\"mail_password\", password)"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              },
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const body = pm.response.json()\r",
                    "const domain = body[\"hydra:member\"][0].domain\r",
                    "\r",
                    "pm.environment.set(\"mail_domain\", domain)"
                  ],
                  "type": "text/javascript",
                  "packages": {},
                  "requests": {}
                }
              }
            ],
            "request": {
              "auth": {
                "type": "noauth"
              },
              "method": "GET",
              "header": [],
              "url": {
                "raw": "https://api.mail.tm/domains",
                "protocol": "https",
                "host": [
                  "api",
                  "mail",
                  "tm"
                ],
                "path": [
                  "domains"
                ]
              }
            },
            "response": []
          },
          {
