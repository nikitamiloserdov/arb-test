      {
        "name": "Registration",
        "item": [
          {
            "name": "Set passcode",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const response = pm.response.json();",
                    "if (response.tokenPair) {",
                    " pm.environment.set('userMfaRefreshToken', response.tokenPair.refreshToken);",
                    " pm.environment.set('userMfaAccessToken', response.tokenPair.accessToken);",
                    "}",
                    ""
                  ],
                  "type": "text/javascript",
                  "packages": {}
                }
              }
            ],
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "x-device-session-token",
                  "value": "{{deviceSessionToken}}",
                  "type": "text"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"passcode\": \"1212\"\n}",
                "options": {
                  "raw": {
                    "language": "json"
                  }
                }
              },
              "url": {
                "raw": "{{r2u-domain}}/auth/registration/passcode",
                "host": [
                  "{{r2u-domain}}"
                ],
                "path": [
                  "auth",
                  "registration",
                  "passcode"
                ]
              }
            },
            "response": []
